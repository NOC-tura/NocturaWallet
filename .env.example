# Copy this file to .env.development (devnet) or .env.production (mainnet)
# and fill in your own API keys. NEVER commit .env.development or .env.production.

HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
HELIUS_WS_URL=wss://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
NETWORK=devnet
API_BASE=http://localhost:3001/v1
SENTRY_DSN=
